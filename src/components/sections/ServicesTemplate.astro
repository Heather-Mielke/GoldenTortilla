---
import { serviceCards } from "../../data/services";
---

<section id="services" class="section">
  <div class="container">
    <h2 style="margin: 0 0 0.4rem; color: var(--brand);">Services</h2>
    <p style="margin: 0 0 1rem; color: var(--muted);">
      Image on top, description below — replace URLs in <code>src/data/services.ts</code> or use files from
      <code>/public</code>.
    </p>
    <div style="display: grid; gap: 1rem; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));">
      {serviceCards.map((svc) => (
        <article class="card media-card">
          <div class="media-card__media">
            <img src={svc.imageSrc} alt={svc.imageAlt} width="640" height="400" loading="lazy" decoding="async" />
          </div>
          <div class="media-card__body">
            <h3>{svc.title}</h3>
            <p>{svc.description}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
