---
import { collageImages } from "../../data/collage";

const collageClasses = [
  "collage-section__cell--a",
  "collage-section__cell--b",
  "collage-section__cell--c",
  "collage-section__cell--d",
  "collage-section__cell--e",
  "collage-section__cell--f",
] as const;
---

<section id="gallery" class="section collage-section" aria-label="Photo collage">
  <div class="container collage-section__inner">
    <h2 class="collage-section__title">Gallery</h2>
    <p class="collage-section__lede">
      Replace these placeholders with client photography — paths live in <code>src/data/collage.ts</code>.
    </p>
    <div class="collage-section__grid" role="presentation">
      {collageImages.map((img, i) => (
        <div class:list={["collage-section__cell", collageClasses[i]]}>
          <button
            type="button"
            class="collage-section__trigger"
            aria-label={`Open image ${i + 1} larger`}
            data-collage-open={img.src}
          >
            <img src={img.src} alt="" width="900" height="600" loading="lazy" decoding="async" />
          </button>
        </div>
      ))}
    </div>
  </div>

  <dialog class="collage-lightbox" id="collage-lightbox" aria-label="Enlarged image">
    <div class="collage-lightbox__shell">
      <button type="button" class="collage-lightbox__close" data-collage-lightbox-close aria-label="Close">
        ×
      </button>
      <img class="collage-lightbox__img" src="" alt="" width="1200" height="800" decoding="async" />
    </div>
  </dialog>
</section>

<script>
  const dialog = document.getElementById("collage-lightbox") as HTMLDialogElement | null;
  const lightboxImg = dialog?.querySelector(".collage-lightbox__img") as HTMLImageElement | null;
  const shell = dialog?.querySelector(".collage-lightbox__shell");

  document.querySelectorAll("[data-collage-open]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const src = btn.getAttribute("data-collage-open");
      if (!dialog || !lightboxImg || !src) return;
      lightboxImg.src = src;
      lightboxImg.alt = "";
      dialog.showModal();
    });
  });

  dialog?.querySelector("[data-collage-lightbox-close]")?.addEventListener("click", () => dialog.close());

  dialog?.addEventListener("click", (e) => {
    if (e.target === dialog) dialog.close();
  });

  shell?.addEventListener("click", (e) => {
    if (e.target === shell) dialog?.close();
  });

  dialog?.addEventListener("close", () => {
    if (lightboxImg) lightboxImg.removeAttribute("src");
  });
</script>
