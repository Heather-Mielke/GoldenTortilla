---
import { siteConfig } from "../../data/site";
import Modal from "../ui/Modal.astro";
---

<section class="section">
  <div class="container card" style="padding: clamp(1.25rem, 4vw, 2.25rem);">
    <p style="margin: 0; text-transform: uppercase; letter-spacing: 0.12em; font-size: 0.75rem; color: var(--brand);">
      Rooted in service, built for growth
    </p>
    <h1 style="margin: 0.7rem 0 0.75rem; font-size: clamp(2rem, 6vw, 3.4rem); line-height: 1.1;">
      {siteConfig.businessName}
    </h1>
    <p style="margin: 0; color: var(--muted); max-width: 56ch;">{siteConfig.tagline}</p>
    <div style="display: flex; gap: 0.7rem; flex-wrap: wrap; margin-top: 1rem; align-items: center;">
      <a class="btn btn-primary" href={siteConfig.ctaPrimaryHref}>{siteConfig.ctaPrimaryLabel}</a>
      <a class="btn btn-secondary" href={siteConfig.ctaSecondaryHref}>{siteConfig.ctaSecondaryLabel}</a>
      <Modal id="offer-modal" title="Current offer" triggerLabel="View offer">
        <p style="margin: 0; color: var(--muted); line-height: 1.55;">
          Drop in seasonal promos, consult booking, or a downloadable guide. Wire this button to any
          <code>dialog</code>
          or third-party widget.
        </p>
      </Modal>
    </div>
  </div>
</section>
