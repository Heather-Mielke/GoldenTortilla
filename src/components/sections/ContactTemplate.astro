---
import { siteConfig } from "../../data/site";
---

<section id="contact" class="section contact-section" aria-labelledby="contact-heading">
  <div class="container">
    <div class="card contact-section__panel">
      <h2 id="contact-heading" class="contact-section__title">Contact</h2>
      <p class="contact-section__lede">
        Example form — wire <code>action</code> to Formspree, Netlify Forms, a server endpoint, or Astro Actions.
        Submit is demo-only (shows a message, does not send).
      </p>

      <div
        class="contact-form-status contact-form-status--success"
        id="contact-demo-success"
        role="status"
        aria-live="polite"
        tabindex="-1"
        hidden
      >
        Thanks — this is a demo; connect your backend to receive real messages.
      </div>

      <form class="contact-form" id="contact-demo-form" novalidate>
        <input type="text" name="company" class="contact-form__hp" tabindex="-1" autocomplete="off" aria-hidden="true" />

        <div class="contact-form__row contact-form__row--split">
          <div class="contact-form__field">
            <label class="contact-form__label" for="contact-name">Name</label>
            <input
              class="contact-form__input"
              id="contact-name"
              name="name"
              type="text"
              required
              autocomplete="name"
              placeholder="Jane Doe"
            />
          </div>
          <div class="contact-form__field">
            <label class="contact-form__label" for="contact-email">Email</label>
            <input
              class="contact-form__input"
              id="contact-email"
              name="email"
              type="email"
              required
              autocomplete="email"
              placeholder="you@example.com"
            />
          </div>
        </div>

        <div class="contact-form__field">
          <label class="contact-form__label" for="contact-phone">Phone <span class="contact-form__optional">(optional)</span></label>
          <input
            class="contact-form__input"
            id="contact-phone"
            name="phone"
            type="tel"
            autocomplete="tel"
            placeholder="(555) 555-5555"
          />
        </div>

        <div class="contact-form__field">
          <label class="contact-form__label" for="contact-topic">Topic</label>
          <select class="contact-form__input contact-form__select" id="contact-topic" name="topic">
            <option value="general">General question</option>
            <option value="quote">Request a quote</option>
            <option value="support">Support</option>
          </select>
        </div>

        <div class="contact-form__field">
          <label class="contact-form__label" for="contact-message">Message</label>
          <textarea
            class="contact-form__input contact-form__textarea"
            id="contact-message"
            name="message"
            required
            rows="5"
            placeholder="Tell us what you need…"
          />
        </div>

        <button type="submit" class="btn btn-primary contact-form__submit">Send message</button>
      </form>

      <div class="contact-section__aside">
        <p class="contact-section__aside-title">Prefer to reach out directly?</p>
        <p class="contact-section__aside-line">
          <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>
        </p>
        <p class="contact-section__aside-line">{siteConfig.phone}</p>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById("contact-demo-form") as HTMLFormElement | null;
  const success = document.getElementById("contact-demo-success") as HTMLElement | null;

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const hp = form.querySelector<HTMLInputElement>('input[name="company"]');
    if (hp?.value) return;

    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    success?.removeAttribute("hidden");
    form.reset();
    success?.focus();
  });
</script>
