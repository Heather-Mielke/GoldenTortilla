---
import type { Testimonial } from "../../data/testimonials";

interface Props {
  items: Testimonial[];
  /** Auto-advance interval in ms */
  autoMs?: number;
}

const { items, autoMs = 5500 } = Astro.props;
const slideCount = items.length;
---

<section
  id="testimonials"
  class="section testimonials-section testimonials-section--brand"
  aria-label="Client testimonials"
  data-slider-root
  data-slider-loop="true"
  data-slider-autoplay={autoMs}
>
  <div class="container">
    <h2 class="testimonials-quotes__title">What Clients Say</h2>
    <p class="testimonials-quotes__hint">
      Text-only quotes — use prev/next or dots to browse ({slideCount} testimonials). Auto-advance pauses on hover.
    </p>
    <div class="slider__viewport testimonials-quote-viewport" data-slider-viewport>
      <ul class="slider__track" data-slider-track style="transform: translateX(0px);">
        {items.map((t) => (
          <li class="slider__slide testimonials-quote-slide" data-slider-slide>
            <blockquote class="testimonials-quote-block">
              <p class="testimonials-quote-text">“{t.quote}”</p>
              <footer class="testimonials-quote-meta">
                <cite class="testimonials-quote-name">{t.name}</cite>
                {t.role ? <span class="testimonials-quote-role"> · {t.role}</span> : null}
              </footer>
            </blockquote>
          </li>
        ))}
      </ul>
    </div>
    <div class="slider__controls testimonials-quote-controls">
      <button type="button" class="slider__btn" data-slider-prev aria-label="Previous testimonial">
        ‹
      </button>
      <div class="slider__dots">
        {items.map((_, i) => (
          <button
            type="button"
            class:list={["slider__dot", i === 0 && "slider__dot--active"]}
            data-slider-dot
            data-slider-index={i}
            aria-label={`Go to testimonial ${i + 1}`}
          />
        ))}
      </div>
      <button type="button" class="slider__btn" data-slider-next aria-label="Next testimonial">
        ›
      </button>
    </div>
  </div>
</section>
