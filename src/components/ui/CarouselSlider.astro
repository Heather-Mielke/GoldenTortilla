---
interface Slide {
  title: string;
  text: string;
}

interface Props {
  slides: Slide[];
}

const { slides } = Astro.props;
---

<section class="slider section" aria-label="Featured slides" data-slider-root data-slider-loop="false">
  <div class="container">
    <h2 class="slider-heading" style="margin: 0 0 1rem; color: var(--brand);">Highlights</h2>
    <div class="slider__viewport" data-slider-viewport>
      <ul class="slider__track" data-slider-track style="transform: translateX(0px);">
        {slides.map((slide) => (
          <li class="slider__slide" data-slider-slide>
            <h3 style="margin: 0 0 0.5rem; font-size: 1.1rem;">{slide.title}</h3>
            <p style="margin: 0; color: var(--muted); line-height: 1.55;">{slide.text}</p>
          </li>
        ))}
      </ul>
    </div>
    <div class="slider__controls">
      <button type="button" class="slider__btn" data-slider-prev aria-label="Previous slide">‹</button>
      <div class="slider__dots">
        {slides.map((_, i) => (
          <button
            type="button"
            class:list={["slider__dot", i === 0 && "slider__dot--active"]}
            data-slider-dot
            data-slider-index={i}
            aria-label={`Go to slide ${i + 1}`}
          />
        ))}
      </div>
      <button type="button" class="slider__btn" data-slider-next aria-label="Next slide">›</button>
    </div>
  </div>
</section>
