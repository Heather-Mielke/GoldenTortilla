---
interface Props {
  id: string;
  title: string;
  triggerLabel?: string;
}

const { id, title, triggerLabel = "Open modal" } = Astro.props;
---

<button type="button" class="btn btn-secondary" data-modal-open={id} aria-haspopup="dialog">
  {triggerLabel}
</button>

<dialog class="modal" id={id} aria-labelledby={`${id}-title`} aria-modal="true">
  <div class="modal__panel card">
    <div class="modal__header">
      <h2 class="modal__title" id={`${id}-title`}>{title}</h2>
      <button type="button" class="modal__close" data-modal-close={id} aria-label="Close dialog">×</button>
    </div>
    <div class="modal__body">
      <slot />
    </div>
    <div class="modal__actions">
      <button type="button" class="btn btn-primary" data-modal-close={id}>Close</button>
    </div>
  </div>
</dialog>

<script define:vars={{ modalId: id }}>
  const dialog = document.getElementById(modalId) as HTMLDialogElement | null;
  if (!dialog) {
    /* no-op */
  } else {
    document.querySelectorAll(`[data-modal-open="${modalId}"]`).forEach((btn) => {
      btn.addEventListener("click", () => dialog.showModal());
    });
    document.querySelectorAll(`[data-modal-close="${modalId}"]`).forEach((btn) => {
      btn.addEventListener("click", () => dialog.close());
    });
    dialog.addEventListener("click", (e) => {
      if (e.target === dialog) dialog.close();
    });
  }
</script>
