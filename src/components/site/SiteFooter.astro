---
import { siteConfig } from "../../data/site";
import { socialLinks } from "../../data/social";
import SocialIcon from "./SocialIcon.astro";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <p class="site-footer__brand">{siteConfig.businessName}</p>
    <p class="site-footer__contact">
      {siteConfig.city} · <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a> · {siteConfig.phone}
    </p>

    <ul class="site-footer__social">
      {socialLinks.map((s) => (
        <li class="site-footer__social-item">
          <a
            class="site-footer__social-link"
            href={s.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={s.label}
          >
            <SocialIcon platform={s.platform} />
          </a>
        </li>
      ))}
    </ul>

    <p class="site-footer__legal">
      <a href="/privacy-policy">Privacy Policy</a>
      <span aria-hidden="true">|</span>
      <a href="/terms">Terms</a>
      <span aria-hidden="true">|</span>
      <a href="https://www.linkedin.com/" target="_blank" rel="noopener noreferrer">Careers</a>
    </p>

    <p class="site-footer__copy">© {year} {siteConfig.businessName}</p>
  </div>
</footer>
