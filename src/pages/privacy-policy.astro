---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Privacy Policy | The Golden Tortilla">
  <section class="section">
    <div class="container legal-page">
      <h1>Privacy Policy</h1>
      <p>
        The Golden Tortilla values your privacy. We only collect the information needed to process orders, respond to
        requests, and improve your experience.
      </p>
      <p>
        Third-party services such as DoorDash and social media platforms may have their own data practices. Please
        review their policies directly when using those services.
      </p>
      <p>For questions about this policy, contact us at hola@thegoldentortilla.com.</p>
    </div>
  </section>
</BaseLayout>
